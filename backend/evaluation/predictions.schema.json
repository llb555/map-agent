{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arcadegent.local/schemas/rag-evaluation-predictions.json",
  "title": "Arcadegent RAG answer predictions",
  "type": "object",
  "required": ["predictions"],
  "additionalProperties": true,
  "properties": {
    "predictions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "answer", "citations"],
        "additionalProperties": true,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "answer": {"type": "string"},
          "citations": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        }
      }
    }
  }
}
