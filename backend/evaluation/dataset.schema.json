{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arcadegent.local/schemas/rag-evaluation-dataset.json",
  "title": "Arcadegent RAG evaluation dataset",
  "type": "object",
  "required": ["name", "version", "cases"],
  "additionalProperties": true,
  "properties": {
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "fact": {
      "oneOf": [
        {"type": "string", "minLength": 1},
        {
          "type": "object",
          "required": ["accepted"],
          "additionalProperties": false,
          "properties": {
            "accepted": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1}
            },
            "contradictions": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            }
          }
        }
      ]
    },
    "document": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "document_id": {"type": "string", "minLength": 1},
        "chunk_id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "source_uri": {"type": "string", "minLength": 1},
        "relevance": {"type": "integer", "minimum": 1, "maximum": 3}
      },
      "anyOf": [
        {"required": ["document_id"]},
        {"required": ["chunk_id"]},
        {"required": ["source_uri"]},
        {"required": ["title"]}
      ]
    },
    "case": {
      "type": "object",
      "required": ["id", "query"],
      "additionalProperties": true,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "query": {"type": "string", "minLength": 1},
        "tags": {"type": "array", "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"}},
        "relevant_documents": {"type": "array", "items": {"$ref": "#/$defs/document"}},
        "expected_context_facts": {"type": "array", "items": {"$ref": "#/$defs/fact"}},
        "required_answer_facts": {"type": "array", "items": {"$ref": "#/$defs/fact"}},
        "forbidden_answer_claims": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "expected_no_answer": {"type": "boolean"}
      },
      "allOf": [
        {
          "if": {"properties": {"expected_no_answer": {"const": true}}, "required": ["expected_no_answer"]},
          "then": {"properties": {"relevant_documents": {"maxItems": 0}}},
          "else": {"required": ["relevant_documents"], "properties": {"relevant_documents": {"minItems": 1}}}
        }
      ]
    }
  }
}
